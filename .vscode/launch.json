{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "IKEv2 receiver",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}/apps/infrastructure/ikev2/receiver.go",
			"envFile": "${workspaceFolder}/apps/infrastructure/ikev2/.env"
		},
		{
			"name": "WireGuard receiver",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}/apps/infrastructure/wireguard/receiver.go",
			"envFile": "${workspaceFolder}/apps/infrastructure/wireguard/.env"
		},
		{
			"name": "Keys Bot",
			"program": "${workspaceFolder}/apps/keys/src/index.ts",
			"request": "launch",
			"skipFiles": ["<node_internals>/**"],
			"type": "node",
			"envFile": "${workspaceFolder}/apps/keys/.env",
			"outFiles": ["${workspaceFolder}/apps/keys/dist/src/**/*.js"],
			"preLaunchTask": "tsc: build - apps/keys/tsconfig.json"
		},
		{
			"name": "Users Bot",
			"program": "${workspaceFolder}/apps/users/src/index.ts",
			"request": "launch",
			"skipFiles": ["<node_internals>/**"],
			"type": "node",
			"envFile": "${workspaceFolder}/apps/users/.env",
			"outFiles": ["${workspaceFolder}/apps/users/dist/src/**/*.js"],
			"preLaunchTask": "tsc: build - apps/users/tsconfig.dev.json"
		},
		{
			"name": "API",
			"program": "${workspaceFolder}/apps/api/src/main.ts",
			"request": "launch",
			"skipFiles": ["<node_internals>/**"],
			"type": "node",
			"envFile": "${workspaceFolder}/apps/api/.env",
			"outFiles": ["${workspaceFolder}/apps/api/dist/src/**/*.js"]
		}
	]
}
